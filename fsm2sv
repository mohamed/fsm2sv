"""
All rights reserved (C) 2021. Mohamed A. Bamakhrama.

A tool to generate synthesizable SystemVerilog finite state machines from YAML
specifications. The idea is to capture the FSM intent in a clear way that
enables the designer to focus on *what* the FSM should do, and leave the code
*details* to the tool. The tool then generates optimized SV RTL in a consistent
style that helps the designer to achieve easier readability and debugability.
The tool also generates a Graphviz dot visualization of the FSM that that can
be used for visual documentation purposes.
"""

__version__ = "1.0"

import io
import sys
import math
import argparse
from collections import deque
from pathlib import Path

import yaml
from jsonschema import Draft202012Validator

INOUT_CHARS = ['(', ')', '<', '>']


class FSMValidationError(ValueError):
    """Raised when FSM YAML validation fails."""


class FSMValidator:
    """Centralized Draft 2020-12 and semantic validation for FSM YAML inputs."""

    @staticmethod
    def format_path(parts):
        out = "fsm"
        for part in parts:
            out += f"[{part}]" if isinstance(part, int) else f".{part}"
        return out

    @classmethod
    def schema_errors(cls, fsm, schema):
        if not isinstance(schema, dict):
            return ["schema: expected mapping at root"]

        try:
            Draft202012Validator.check_schema(schema)
        except Exception as exc:  # jsonschema.exceptions.SchemaError
            return [f"schema: invalid Draft 2020-12 schema: {exc}"]

        validator = Draft202012Validator(schema)
        return [
            f"{cls.format_path(list(err.path))}: {err.message}"
            for err in sorted(validator.iter_errors(fsm), key=lambda e: list(e.path))
        ]

    @staticmethod
    def port_names(items, section, errors):
        names = set()
        if not isinstance(items, list):
            return names

        for idx, entry in enumerate(items):
            if not isinstance(entry, dict) or len(entry) != 1:
                continue
            name = next(iter(entry.keys()))
            if name in names:
                errors.append(f"{section}[{idx}]: Duplicate signal name '{name}'")
            else:
                names.add(name)
        return names

    @staticmethod
    def check_output_assignment_list(text, output_names, path, errors):
        if not (text.startswith("<") and text.endswith(">")):
            errors.append(f"{path}: Output assignment must be enclosed in '<' and '>'")
            return

        stmts = [s.strip() for s in text[1:-1].split(";") if s.strip()]
        if not stmts:
            errors.append(f"{path}: Expected at least one output assignment")
            return

        for stmt in stmts:
            lhs_rhs = [s.strip() for s in stmt.split("=")]
            if len(lhs_rhs) != 2:
                errors.append(f"{path}: Malformed assignment '{stmt}', expected 'name = expr'")
                continue
            lhs, rhs = lhs_rhs
            if lhs not in output_names:
                errors.append(f"{path}: Unknown output '{lhs}' in assignment")
            if not rhs:
                errors.append(f"{path}: Missing RHS expression for output '{lhs}'")

    @classmethod
    def semantic_errors(cls, fsm):
        if not isinstance(fsm, dict):
            return []

        errors = []
        output_names = cls.port_names(fsm.get("outputs"), "outputs", errors)
        input_names = cls.port_names(fsm.get("inputs"), "inputs", errors)

        encoding = fsm.get("encoding", "onehot")
        if encoding not in {"onehot", "counter", "gray"}:
            errors.append("encoding: must be one of onehot, counter, gray")

        overlap = sorted(output_names.intersection(input_names))
        if overlap:
            errors.append(f"signals: Names overlap between inputs and outputs: {', '.join(overlap)}")

        transitions = fsm.get("transitions")
        states = set()
        dst_states = []

        if isinstance(transitions, list):
            for sidx, state_entry in enumerate(transitions):
                if not isinstance(state_entry, dict) or len(state_entry) != 1:
                    continue

                state_name, lines = next(iter(state_entry.items()))
                if state_name in states:
                    errors.append(f"transitions[{sidx}]: Duplicate state definition '{state_name}'")
                states.add(state_name)

                if not isinstance(lines, list):
                    continue

                has_direct_arc = False
                for lidx, line in enumerate(lines):
                    lpath = f"transitions[{sidx}].{state_name}[{lidx}]"
                    if not isinstance(line, str):
                        continue

                    elems = [part.strip() for part in line.split(",")]
                    if not elems:
                        continue

                    if elems[0].startswith("("):
                        if len(elems) >= 2 and elems[1]:
                            if elems[1].startswith(tuple(INOUT_CHARS)):
                                errors.append(f"{lpath}: Invalid next_state leading character")
                            else:
                                dst_states.append(elems[1])
                        if len(elems) == 3:
                            cls.check_output_assignment_list(elems[2], output_names, lpath, errors)
                    elif elems[0].startswith("<"):
                        cls.check_output_assignment_list(elems[0], output_names, lpath, errors)
                    else:
                        if has_direct_arc:
                            errors.append(
                                f"{lpath}: Only one direct next_state transition is allowed per state"
                            )
                            continue
                        has_direct_arc = True
                        if elems[0].startswith(tuple(INOUT_CHARS)):
                            errors.append(f"{lpath}: Invalid next_state leading character")
                        elif elems[0]:
                            dst_states.append(elems[0])

        if len(states) <= 1:
            errors.append("transitions: At least two states must be defined")

        for dst in dst_states:
            if dst not in states:
                errors.append(f"transitions: Destination state '{dst}' is not defined")

        initial_state = fsm.get("initial_state")
        if isinstance(initial_state, str) and initial_state not in states:
            errors.append(f"initial_state: '{initial_state}' is not defined in transitions")

        return errors

    @classmethod
    def validate_fsm_yaml(cls, fsm, schema):
        return cls.schema_errors(fsm, schema) + cls.semantic_errors(fsm)

    @staticmethod
    def load_schema_or_exit():
        schema_path = Path(__file__).resolve().with_name("fsm2sv_schema.yml")
        try:
            with open(schema_path, 'r', encoding='utf-8') as schema_file:
                return yaml.safe_load(schema_file)
        except FileNotFoundError as exc:
            sys.exit(f"Error: schema file not found: {exc}")
        except yaml.YAMLError as exc:
            sys.exit(f"Error: failed to parse schema YAML: {exc}")
        except IOError as exc:
            sys.exit(f"Error: failed to read schema file: {exc}")


class VerilogTBVisitor:
    """
    Generates Verilog testbench
    """
    def __init__(self):
        self.buf = io.StringIO()

    def visit_fsm(self, fsm):
        """Visit the FSM
        """
        if not isinstance(fsm, FSM):
            raise TypeError("visit_fsm expects an FSM instance")
        dump = self.buf.write
        dump("`timescale 1ns/1ps\n\n")
        dump(f"module {fsm.name}_tb;\n\n")
        dump("localparam integer PERIOD = 10;\n\n")
        rst = "rst_ni" if fsm.rst_active_low else "rst_i"
        dump(f"logic clk_i, {rst};\n")
        dump("// inputs\n")
        for name, inp in fsm.inputs.items():
            dump(f"logic [{inp.width-1}:0] {name};\n")
        dump("\n")
        dump("// outputs\n")
        for name, out in fsm.outputs.items():
            dump(f"wire [{out.width-1}:0] {name};\n")
        dump("\n")
        dump("integer i;\n\n")
        dump("initial begin\n")
        dump(f'  $dumpfile("{fsm.name}.vcd");\n')
        dump(f'  $dumpvars(0, {fsm.name}_tb);\n')
        dump("  clk_i = 0;\n")
        rst_val = 0 if fsm.rst_active_low else 1
        dump(f"  {rst} = {rst_val};\n")
        rst_val = rst_val ^ 1
        dump(f"  #(2*PERIOD) {rst} = {rst_val};\n")
        self.generate_values(fsm)
        dump("  $finish;\n")
        dump("end\n\n")
        dump("always begin\n")
        dump("  #(PERIOD / 2) clk_i = !clk_i;\n")
        dump("end\n\n")
        dump(f"{fsm.name} dut (\n")
        dump("  .clk_i(clk_i),\n")
        dump(f"  .{rst}({rst}),\n")
        for name, inp in fsm.inputs.items():
            dump(f"  .{name}({name}),\n")
        for i, name in enumerate(fsm.outputs):
            comma = "," if i < (len(fsm.outputs)-1) else ""
            dump(f"  .{name}({name}){comma}\n")
        dump(");\n\n")
        dump("endmodule\n")

    def generate_values(self, fsm):
        """Generate simulation random values
        """
        if not isinstance(fsm, FSM):
            raise TypeError("generate_values expects an FSM instance")
        dump = self.buf.write
        dump("  for (i = 0; i < 10000; i++) begin\n")
        for name, inp in fsm.inputs.items():
            dump("    /* verilator lint_off WIDTHTRUNC */\n")
            dump(f"    {name} = $random % {(2 ** inp.width)};\n")
        dump("    #(PERIOD);\n")
        dump("  end\n")


class DotVisitor:   # pylint: disable=too-few-public-methods
    """
    Generates Graphviz dot file from an FSM object
    """
    def __init__(self):
        self.buf = io.StringIO()

    def visit_fsm(self, fsm):
        """Visits the given FSM and serializes it to self.buf

        Args:
            fsm: The state machine object
        """
        if not isinstance(fsm, FSM):
            raise TypeError("visit_fsm expects an FSM instance")
        dump = self.buf.write
        dump(f"digraph {fsm.name} {{\n")
        dump("  edge[splines=\"curved\"];\n\n")
        for state, value in fsm.states.items():
            label = f"{state}"
            moore = ""
            if value.moore_outputs:
                for out, val in value.moore_outputs.items():
                    moore += f"\n{out}={val},"
            label += moore
            shape = "doublecircle" if state == fsm.initial_state else "circle"
            dump(f"  {state}[label=\"{label}\",shape={shape}];\n")
        dump("\n")
        for trans in fsm.transitions:
            dump(f"  {trans.src_state} -> {trans.dst_state}")
            label = ""
            if trans.condition is not None:
                label = f"[label=\"{trans.condition}"
            mealy = ""
            if trans.mealy_outputs:
                mealy = " / "
                for out, val in trans.mealy_outputs.items():
                    mealy += f"{out}={val},"
            label += mealy
            if trans.condition is not None:
                label += "\"]"
            dump(f"{label};\n")
        dump("}")


class SVVisitor:
    """
    Produces SystemVerilog module implementing the FSM
    """
    def __init__(self):
        self.buf = io.StringIO()
        self.idx = 0

    def tab(self):
        """prints variable indentation
        """
        return "  " * self.idx

    def visit_fsm(self, fsm):   # pylint: disable=too-many-statements
        """FSM main visitor

        Args:
            fsm: The FSM object
        """
        if not isinstance(fsm, FSM):
            raise TypeError("visit_fsm expects an FSM instance")
        dump = self.buf.write
        tab = self.tab
        dump("`timescale 1ns/1ps\n\n")
        dump(f"{tab()}module {fsm.name} (\n")
        self.idx += 1
        dump(f"{tab()}// inputs\n")
        for name, inp in fsm.inputs.items():
            dump(f"{tab()}input  logic [{inp.width-1}:0]   {name},\n")
        dump(f"{tab()}// outputs\n")
        for name, outp in fsm.outputs.items():
            dump(f"{tab()}output logic [{outp.width-1}:0]   {name},\n")
        dump(f"{tab()}// clock and reset\n")
        dump(f"{tab()}input  logic         clk_i,\n")
        rst = "rst_ni" if fsm.rst_active_low else "rst_i"
        rst_edge = "negedge" if fsm.rst_active_low else "posedge"
        dump(f"{tab()}input  logic         {rst}\n")
        self.idx -= 1
        dump(f"{tab()});\n")
        self.idx += 1
        self.visit_states(fsm.states, fsm.encoding)
        for name, outp in fsm.outputs.items():
            if outp.reg:
                dump(f"{tab()}logic [{outp.width-1}:0]")
                dump(f" {name}_d, {name}_q;\n")
        dump("\n")
        for name, outp in fsm.outputs.items():
            if outp.reg:
                dump(f"{tab()}assign {name} = {name}_q;\n")
        dump("\n")
        dump(f"{tab()}always_ff @(posedge clk_i")
        if not fsm.rst_async:
            dump(") begin\n")
        else:
            dump(f", {rst_edge} {rst}) begin\n")
        self.idx += 1
        reset_op = "!" if fsm.rst_active_low else ""
        dump(f"{tab()}if ({reset_op}{rst}) begin\n")
        self.idx += 1
        dump(f"{tab()}state_q <= {fsm.initial_state};\n")
        for outp, port_val in fsm.outputs.items():
            if port_val.reg:
                dump(f"{tab()}{outp}_q <= '0;\n")
        self.idx -= 1
        dump(f"{tab()}end else begin\n")
        self.idx += 1
        dump(f"{tab()}state_q <= state_d;\n")
        for outp, port_val in fsm.outputs.items():
            if port_val.reg:
                dump(f"{tab()}{outp}_q <= {outp}_d;\n")
        self.idx -= 1
        dump(f"{tab()}end\n")
        self.idx -= 1
        dump(f"{tab()}end\n")
        dump("\n")
        self.visit_transitions(fsm)
        dump("\n")
        dump("`ifdef FORMAL\n")
        dump(f"{tab()}// SV assertions\n")
        self.visit_sva(fsm)
        dump("`endif  // FORMAL\n")
        dump("endmodule\n")

    def visit_states(self, states, encoding):
        """
        Visit states
        """
        if not isinstance(states, dict):
            raise TypeError("states must be a dictionary")
        if not states:
            raise ValueError("states cannot be empty")
        dump = self.buf.write
        tab = self.tab
        num_states = math.ceil(math.log(len(states), 2))
        if encoding == "onehot":
            num_states = len(states)
        else:
            num_states = max(1, num_states)
        dump("\n")
        dump("`ifdef USE_ENUM_STATE\n")
        dump(f"{tab()}typedef enum logic [{num_states-1}:0] {{\n")
        self.idx += 1
        for idx, (state, value) in enumerate(states.items()):
            dump(f"{tab()}{state} = {num_states}'d{value.encoding}")
            dump(",\n" if idx < (len(states) - 1) else "\n")
        self.idx -= 1
        dump(f"{tab()}}} state_t;\n")
        dump("`else\n")
        for state, value in states.items():
            dump(f"{tab()}localparam logic [{num_states-1}:0]")
            dump(f" {state} = {num_states}'d{value.encoding};\n")
        dump(f"{tab()}typedef logic [{num_states-1}:0] state_t;\n")
        dump("`endif  // USE_ENUM_STATE\n\n")
        dump(f"{tab()}state_t state_d, state_q;\n")

    def visit_transitions(self, fsm):
        """
        Visit transitions
        """
        if not isinstance(fsm, FSM):
            raise TypeError("visit_transitions expects an FSM instance")
        dump = self.buf.write
        tab = self.tab
        dump(f"{tab()}always_comb begin\n")
        self.idx += 1
        dump(f"{tab()}// default values\n")
        dump(f"{tab()}state_d = state_q;\n")
        for outp, value in fsm.outputs.items():
            src = outp + "_q" if value.reg else "'0"
            dst = outp + "_d" if value.reg else outp
            dump(f"{tab()}{dst} = {src};\n")
        dump(f"{tab()}unique case (state_q)\n")
        self.idx += 1
        for state in fsm.states:
            dump(f"{tab()}{state}: begin\n")
            self.idx += 1
            for moore, value in fsm.states[state].moore_outputs.items():
                dst = moore + "_d" if fsm.outputs[moore].reg else moore
                dump(f"{tab()}{dst} = {value};\n")
            has_condition = False
            for trans in fsm.transitions:
                if trans.src_state == state:
                    if not has_condition:
                        if trans.condition is not None:
                            dump(f"{tab()}if {trans.condition} begin\n")
                            self.idx += 1
                            has_condition = True
                    else:
                        if trans.condition is not None:
                            dump(f" else if {trans.condition} begin\n")
                            self.idx += 1
                        else:
                            dump(" else begin\n")
                            self.idx += 1
                    if trans.dst_state not in fsm.states:
                        raise FSMValidationError(
                            f"Transition destination '{trans.dst_state}' is undefined"
                        )
                    dump(f"{tab()}state_d = {trans.dst_state};\n")
                    if trans.mealy_outputs:
                        for mealy, value in trans.mealy_outputs.items():
                            reg = fsm.outputs[mealy].reg
                            dst = mealy + "_d" if reg else mealy
                            dump(f"{tab()}{dst} = {value};\n")
                    if has_condition:
                        self.idx -= 1
                        dump(f"{tab()}end")
            self.idx -= 1
            dump(f"\n{tab()}end\n")
        dump(f"{tab()}default: begin\n")
        self.idx += 1
        dump(f"{tab()}state_d = {fsm.initial_state};\n")
        self.idx -= 1
        dump(f"{tab()}end\n")
        self.idx -= 1
        dump(f"{tab()}endcase\n")
        self.idx -= 1
        dump(f"{tab()}end\n")

    def visit_sva(self, fsm):
        """SystemVerilog Assertions
        """
        if not isinstance(fsm, FSM):
            raise TypeError("visit_sva expects an FSM instance")
        dump = self.buf.write
        tab = self.tab
        rst = "rst_ni" if fsm.rst_active_low else "rst_i"
        rst_asserted = f"!{rst}" if fsm.rst_active_low else rst
        rst_not_asserted = f"{rst}" if fsm.rst_active_low else rst

        dump(f"{tab()}always_comb begin\n")
        self.idx += 1
        dump(f"{tab()}if ({rst_not_asserted}) begin\n")
        self.idx += 1
        # Mutual exclusion assertion (always applicable)
        if fsm.encoding == "onehot":
            dump(
                f"{tab()}assert ($onehot(state_q)) "
                "else $error(\"state_q is not onehot-legal\");\n"
            )
        else:
            states = ", ".join(fsm.state_set)
            dump(
                f"{tab()}assert (state_q inside {{{states}}}) "
                "else $error(\"state_q is not a legal encoded state\");\n"
            )

        # Reachability assertions (only if unreachable states exist)
        for state in fsm.unreachable_states:
            dump(
                f"{tab()}assert (state_q != {state}) "
                "else $error(\"Reached statically unreachable state\");\n"
            )

        # Liveness assertions (only if guaranteed-exit states exist)
        for state in fsm.guaranteed_exit_states:
            dump(
                f"{tab()}assert (!(state_q == {state} && state_d == {state})) "
                f"else $error(\"No progress from guaranteed-exit state {state}\");\n"
            )

        # Moore output invariants
        for state in fsm.state_set:
            for moore, value in fsm.states[state].moore_outputs.items():
                dst = moore + "_d" if fsm.outputs[moore].reg else moore
                dump(
                    f"{tab()}assert (!(state_q == {state}) || ({dst} == {value})) "
                    f"else $error(\"Moore output mismatch in state {state}: {dst}\");\n"
                )

        # Transition legality, Mealy checks, transition covers, and overlap checks
        for state in fsm.state_set:
            legal_dsts = sorted({trans.dst_state for trans in fsm.transitions_by_src[state]})
            legal_set = ", ".join(legal_dsts)
            dump(
                f"{tab()}assert (!(state_q == {state}) || (state_d inside {{{legal_set}}})) "
                f"else $error(\"Illegal next-state from {state}\");\n"
            )

            for idx_a, cond_a in enumerate(fsm.conditional_transition_conditions[state]):
                if fsm.conditional_transition_conditions[state][idx_a+1:]:
                    dump(f"{tab()}`ifdef ENABLE_OVERLAP_CHECK\n")
                self.idx += 1
                for cond_b in fsm.conditional_transition_conditions[state][idx_a+1:]:
                    dump(
                        f"{tab()}assert (!((state_q == {state}) && ({cond_a}) && ({cond_b}))) "
                        f"else $error(\"Overlapping transition guards in state {state}\");\n"
                    )
                self.idx -= 1
                if fsm.conditional_transition_conditions[state][idx_a+1:]:
                    dump(f"{tab()}`endif\n")

            for trans, guard in fsm.transition_guard_clauses[state]:
                dump(
                    f"{tab()}assert (!({guard}) || (state_d == {trans.dst_state})) "
                    f"else $error(\"Transition mismatch: {state} -> {trans.dst_state}\");\n"
                )
                dump(f"{tab()}cover ({guard} && (state_d == {trans.dst_state}));\n")
                for mealy, value in trans.mealy_outputs.items():
                    dst = mealy + "_d" if fsm.outputs[mealy].reg else mealy
                    dump(
                        f"{tab()}assert (!({guard}) || ({dst} == {value})) "
                        f"else $error(\"Mealy output mismatch on {state}->{trans.dst_state}: {dst}\");\n"
                    )
        self.idx -= 1
        dump(f"{tab()}end\n")
        self.idx -= 1
        dump(f"{tab()}end\n")

        # Sequential transition correctness and reset/init helpers
        for state in fsm.state_set:
            for trans, guard in fsm.transition_guard_clauses[state]:
                dump(
                    f"{tab()}assert property (@(posedge clk_i) disable iff ({rst_asserted}) "
                    f"({guard}) |=> (state_q == {trans.dst_state}));\n"
                )

        dump(
            f"{tab()}assert property (@(posedge clk_i) ({rst_asserted}) "
            f"|=> (state_q == {fsm.initial_state}));\n"
        )
#        dump(f"{tab()}initial begin\n")
#        self.idx += 1
#        dump(f"{tab()}assume ({rst_asserted});\n")
#        self.idx -= 1
#        dump(f"{tab()}end\n")


class Port:   # pylint: disable=too-few-public-methods
    """
    Base class for input/output ports
    """
    def __init__(self, name, width):
        if not isinstance(name, str):
            raise TypeError("Port name must be a string")
        if not isinstance(width, int) or width <= 0:
            raise ValueError("Port width must be a positive integer")
        self.name = name
        self.width = width

    def __repr__(self):
        return f"Port {self.name} (width: {self.width})"


class InPort(Port):   # pylint: disable=too-few-public-methods
    """
    Input port class
    """
    def __repr__(self):
        return f"InPort {self.name} (width: {self.width})"


class OutPort(Port):   # pylint: disable=too-few-public-methods
    """
    Output port class
    """
    def __init__(self, name, width, reg):
        super().__init__(name, width)
        if reg is None:
            raise ValueError("Output field 'reg' must not be None")
        self.reg = reg

    def __repr__(self):
        _ = f"OutPort {self.name} (width: {self.width}, reg: {self.reg})"
        return _


class State:   # pylint: disable=too-few-public-methods
    """State class

    Stores the state name, encoding, and a dict holding Moore's outputs
    """
    def __init__(self, name, encoding, moore_outputs):
        if not isinstance(name, str):
            raise TypeError("State name must be a string")
        if not isinstance(encoding, int) or encoding < 0:
            raise ValueError("State encoding must be a non-negative integer")
        if not isinstance(moore_outputs, dict):
            raise TypeError("moore_outputs must be a dictionary")
        self.name = name
        self.encoding = encoding
        self.moore_outputs = moore_outputs

    def __repr__(self):
        _ = f"State {self.name} (encoding: {self.encoding}, "
        _ += f"moore_outputs = {self.moore_outputs})"
        return _


class Transition:
    """Transition class

    Represents a state transition. Stores the source and destination states,
    the transition condition (if any), and a dict of Mealy outputs
    """
    def __init__(self, src_state, dst_state, condition, mealy_outputs):
        if not isinstance(src_state, str):
            raise TypeError("Transition source state must be a string")
        if not isinstance(dst_state, str):
            raise TypeError("Transition destination state must be a string")
        if not (isinstance(condition, str) or condition is None):
            raise TypeError("Transition condition must be a string or None")
        if not isinstance(mealy_outputs, dict):
            raise TypeError("Transition mealy_outputs must be a dictionary")
        self.src_state = src_state
        self.dst_state = dst_state
        self.condition = condition
        self.mealy_outputs = mealy_outputs

    def __eq__(self, other):
        equal = self.condition == other.condition and \
                self.src_state == other.src_state and \
                self.dst_state == other.dst_state and \
                self.mealy_outputs == other.mealy_outputs
        return equal

    def __lt__(self, other):
        if self.condition is not None and other.condition is None:
            return True
        if self.condition is not None and other.condition is not None:
            return self.condition < other.condition
        return False

    def __repr__(self):
        _ = f"Transition from {self.src_state} to "
        _ += f"{self.dst_state} (condition = \"{self.condition}\", "
        _ += f"mealy_outputs = {self.mealy_outputs})"
        return _


class FSM:   # pylint: disable=too-many-instance-attributes
    """
    FSM class

    Stores the FSM representation. Can be serialized into SystemVerilog
    and/or Graphviz dot
    """
    SCHEMA_VERSION = "1.0"

    def __init__(self, fsm):
        if not isinstance(fsm, dict):
            raise TypeError("FSM YAML root must be a mapping")
        if "version" not in fsm:
            raise ValueError("Missing required 'version' field in YAML schema")
        if str(fsm["version"]) != self.SCHEMA_VERSION:
            raise ValueError(
                f"Unsupported schema version '{fsm['version']}'. "
                f"Expected '{self.SCHEMA_VERSION}'"
            )
        self.transitions = []
        self.states = {}
        self.inputs = {}
        self.outputs = {}
        self.name = fsm["name"]
        self.handle_rst(fsm.get("reset", None))
        self.handle_inputs(fsm.get("inputs", {}))
        self.handle_outputs(fsm.get("outputs", {}))
        self.encoding = fsm.get("encoding", "onehot")
        self.handle_transitions(fsm.get("transitions", {}))
        self.set_state_encoding()
        self.initial_state = fsm["initial_state"]
        self.build_analysis_data()

    def handle_rst(self, rst):
        """
        Parse reset section
        """
        self.rst_async = rst.get("asynchronous", True)
        self.rst_active_low = rst.get("active_low", False)

    def handle_inputs(self, inputs):
        """
        Parse inputs
        """
        for inport in inputs:
            for key, val in inport.items():
                port = InPort(key, val["width"])
                self.inputs[key] = port

    def handle_outputs(self, outputs):
        """
        Parse outputs
        """
        for outport in outputs:
            for key, val in outport.items():
                port = OutPort(key, val["width"], val["reg"])
                self.outputs[key] = port

    def _encoding_value(self, idx):
        """
        Return integer encoding value according to selected strategy.
        """
        if self.encoding == "onehot":
            return 1 << idx
        if self.encoding == "counter":
            return idx
        if self.encoding == "gray":
            return idx ^ (idx >> 1)
        raise FSMValidationError("Invalid encoding method")

    def set_state_encoding(self):
        """
        Set the encoding for each state
        """
        for idx, (_, value) in enumerate(self.states.items()):
            value.encoding = self._encoding_value(idx)
        for state_x, val_x in self.states.items():
            for state_y, val_y in self.states.items():
                if state_x != state_y and val_x.encoding == val_y.encoding:
                    raise FSMValidationError("State encodings must be unique")

    def build_analysis_data(self):
        """
        Build reusable graph and encoding analysis data.
        """
        self.state_set = list(self.states.keys())
        self.state_encoding_map = {
            state: self.states[state].encoding for state in self.state_set
        }
        self.transition_graph = {state: [] for state in self.state_set}
        for trans in self.transitions:
            self.transition_graph.setdefault(trans.src_state, []).append(trans.dst_state)

        self.reachable_states = set()
        pending = deque([self.initial_state])
        while pending:
            state = pending.popleft()
            if state in self.reachable_states:
                continue
            self.reachable_states.add(state)
            for dst in self.transition_graph.get(state, []):
                if dst not in self.reachable_states:
                    pending.append(dst)

        self.unreachable_states = [
            state for state in self.state_set if state not in self.reachable_states
        ]

        self.guaranteed_exit_states = []
        for state in self.state_set:
            out_states = self.transition_graph.get(state, [])
            if out_states and all(dst != state for dst in out_states):
                self.guaranteed_exit_states.append(state)

        self.transitions_by_src = {state: [] for state in self.state_set}
        for trans in self.transitions:
            self.transitions_by_src[trans.src_state].append(trans)

        self.conditional_transition_conditions = {state: [] for state in self.state_set}
        self.transition_guard_clauses = {state: [] for state in self.state_set}
        for state in self.state_set:
            prev_conditions = []
            for trans in self.transitions_by_src[state]:
                if trans.condition is not None:
                    cond = trans.condition
                    if prev_conditions:
                        guard = f"(state_q == {state}) && ({cond})"
                        for prev_cond in prev_conditions:
                            guard += f" && !({prev_cond})"
                    else:
                        guard = f"(state_q == {state}) && ({cond})"
                    prev_conditions.append(cond)
                    self.conditional_transition_conditions[state].append(cond)
                else:
                    guard = f"(state_q == {state})"
                    for prev_cond in prev_conditions:
                        guard += f" && !({prev_cond})"
                self.transition_guard_clauses[state].append((trans, guard))


    def parse_output_line(self, line):
        """
        Parse output lines
        """
        stmts = line.strip('<>').split(";")
        outputs = {}
        for stmt in stmts:
            outs = list(map(str.strip, stmt.split("=")))
            outputs[outs[0]] = outs[1]
        return outputs

    def handle_transitions(self, transitions):
        """
        Parse state transitions
        """
        # We initialize the states here with incrementing enocdings
        # These enocdings will later be overwritten in set_state_encoding
        idx = 0
        for state in transitions:
            for key, edges in state.items():
                moore_outs = {}
                unconditional_next_state_set = False
                for edge in edges:
                    elems = edge.split(',')
                    elems = list(map(str.strip, elems))
                    # Case 1: transition with a condition: (), STATE [, <>]
                    if elems[0].startswith('('):
                        mealy = elems[2] if len(elems) == 3 else None
                        mealy_outs = {}
                        if mealy is not None:
                            mealy_outs = self.parse_output_line(mealy)
                        trans = Transition(key, elems[1], elems[0], mealy_outs)
                        self.transitions.append(trans)
                    # Case 2: Moore's output: <>
                    elif elems[0].startswith('<'):
                        moore_outs = self.parse_output_line(elems[0])
                    # Case 3: transition with no condition: just next state
                    else:
                        trans = Transition(key, elems[0], None, {})
                        self.transitions.append(trans)
                        unconditional_next_state_set = True
                if not unconditional_next_state_set:
                    # if no unconditional next state is set for this state, we add a self-loop
                    trans = Transition(key, key, None, {})
                    self.transitions.append(trans)
                self.states[key] = State(key, idx, moore_outs)
            idx += 1
        # We store the transitions based on their conditions to ensure
        # correct generation of the if/else if/else block.
        # The condition-less arcs must be at the end of the list after
        # all the arcs with conditions
        self.transitions.sort()

    def accept(self, visitor):
        """
        Accept a visitor
        """
        if not isinstance(visitor,
                  (SVVisitor,
                   DotVisitor,
                   VerilogTBVisitor)):
            raise TypeError("Unsupported visitor type")
        visitor.visit_fsm(self)

    def __repr__(self):
        _ = f" -- FSM: {self.name}\n"
        _ += f" -- Reset: async = {self.rst_async}, "
        _ += f"active_low = {self.rst_active_low}\n"
        _ += f" -- Inputs: {self.inputs}\n"
        _ += f" -- Outputs: {self.outputs}\n"
        _ += f" -- Initial State: {self.initial_state}\n"
        _ += f" -- Transitions: {self.transitions}\n"
        return _


def main():
    """
    main function of the tool
    """
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("-i", metavar="fsm.yaml", type=str, required=True,
                        help="Input FSM YAML description")
    parser.add_argument("-o", metavar="fsm.sv", type=str,
                        help="Generate SystemVerilog implementation")
    parser.add_argument("-d", metavar="fsm.dot", type=str,
                        help="Generate Graphviz dot file")
    parser.add_argument("-t", metavar='tb.v', type=str,
                        help="Generate Verilog testbench")
    parser.add_argument('--version', action='version',
                        version='%(prog)s ' + __version__)
    args = parser.parse_args()

    if not args.o and not args.d and not args.t:
        sys.exit("Error: must specify at least -o, -d, or -t!")

    schema_doc = FSMValidator.load_schema_or_exit()

    with open(args.i, 'r', encoding='utf-8') as stream:
        try:
            fsm_yml = yaml.safe_load(stream)
            errors = FSMValidator.validate_fsm_yaml(fsm_yml, schema_doc)
            if errors:
                errmsg = "Validation failed:\n"
                errmsg += "\n".join([f"  {idx}. {err}" for idx, err in enumerate(errors, start=1)])
                raise FSMValidationError(errmsg)
            fsm = FSM(fsm_yml)
            if args.o:
                visitor = SVVisitor()
                fsm.accept(visitor)
                with open(args.o, 'w', encoding='utf-8') as outf:
                    outf.write(visitor.buf.getvalue())
                    visitor.buf.close()
            if args.d:
                visitor = DotVisitor()
                fsm.accept(visitor)
                with open(args.d, 'w', encoding='utf-8') as dotf:
                    dotf.write(visitor.buf.getvalue())
                    visitor.buf.close()
            if args.t:
                visitor = VerilogTBVisitor()
                fsm.accept(visitor)
                with open(args.t, 'w', encoding='utf-8') as tbf:
                    tbf.write(visitor.buf.getvalue())
                    visitor.buf.close()
        except yaml.YAMLError as exc:
            sys.exit(str(exc))
        except FSMValidationError as exc:
            sys.exit(str(exc))
        except IOError as exc:
            sys.exit(str(exc))


if __name__ == "__main__":
    main()
    sys.exit(0)
